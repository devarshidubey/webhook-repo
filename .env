# Flask
SECRET_KEY=your-secret-key
FLASK_APP=wsgi.py
FLASK_DEBUG=1

# MongoDB
MONGO_URI=mongodb://admin:secret@mongo:27017/webhookdb?authSource=admin
MONGO_TEST_URI=mongodb://admin:secret@mongo:27017/testdb?authSource=admin

# Mongo root credentials (used by docker-compose)
MONGO_USER=admin
MONGO_PASSWORD=secret